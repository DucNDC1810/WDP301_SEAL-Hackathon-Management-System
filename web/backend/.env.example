# Server
PORT=5001
NODE_ENV=development
SERVER_URL=http://localhost:5001
CLIENT_URL=http://localhost:5173

# MongoDB
MONGODB_CONECTION_STRING=mongodb+srv://<user>:<password>@cluster.mongodb.net
DB_DATABASE=seal_hackathon

# JWT
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
# Tạo tại: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:5001/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitHub OAuth
# Tạo tại: https://github.com/settings/developers → New OAuth App
# Authorization callback URL: http://localhost:5001/api/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Email Service (for email verification)
# Gmail configuration:
# 1. Enable 2-Factor Authentication on Gmail account
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Generate App Password (16 characters)
# 4. Use the app password below (remove spaces)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-character-app-password
